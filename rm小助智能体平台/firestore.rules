rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // For this demo with custom username login (no Firebase Auth),
    // we allow public access to the users collection.
    match /users/{userId} {
      allow read, write: if true;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
